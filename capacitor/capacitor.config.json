{
  "appId": "com.privacychase.social",
  "appName": "PrivacyChase Social",
  "webDir": "../web",
  "bundledWebRuntime": false,
  "server": {
    "androidScheme": "https"
  },
  "ios": {
    "scheme": "PrivacyChase",
    "backgroundColor": "#0a0a0f",
    "contentInset": "always",
    "allowsLinkPreview": false,
    "scrollEnabled": false
  },
  "android": {
    "backgroundColor": "#0a0a0f",
    "allowMixedContent": false,
    "captureInput": true
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 1500,
      "launchAutoHide": true,
      "backgroundColor": "#0a0a0f",
      "androidSplashResourceName": "splash",
      "androidScaleType": "CENTER_CROP",
      "showSpinner": false,
      "iosSpinnerStyle": "small",
      "spinnerColor": "#4ade80",
      "splashFullScreen": true,
      "splashImmersive": true
    },
    "StatusBar": {
      "style": "DARK",
      "backgroundColor": "#0a0a0f",
      "overlaysWebView": true
    },
    "Keyboard": {
      "resize": "body",
      "style": "DARK",
      "resizeOnFullScreen": true
    },
    "Camera": {
      "permissions": ["camera"]
    }
  }
}
